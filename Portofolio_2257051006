        </div>
    </section>

    <section>
        <h2>Kuis Grafika Komputer</h2>

        <div class="grid">

            <div class="card">
                <h3>Kuis 1</h3>
                <p>Persamaan Misteri</p>
                <a class="btn" href="https://youtu.be/_c3IufGLbvE" target="_blank">Lihat Video</a>
            </div>

            <div class="card">
                <h3>Kuis 2</h3>
                <p>Transformasi 2D</p>
                <a class="btn" href="https://youtu.be/ognPWNR_Y2g" target="_blank">Lihat Video</a>
            </div>

            <div class="card">
                <h3>Kuis 3</h3>
                <p>Algoritma Pemotongan Garis</p>
