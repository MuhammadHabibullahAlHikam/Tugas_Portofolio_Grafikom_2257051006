<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Portofolio Muhammad Habibullah Al Hikam</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#38bdf8;
    color:#1e293b;
    line-height:1.6;
}

header{
    text-align:center;
    padding:60px 20px;
    background:white;
}

.profile{
    width:150px;
    height:150px;
    border-radius:50%;
    object-fit:cover;
    margin-bottom:20px;
    border:4px solid #38bdf8;
}

.container{
    width:90%;
    max-width:1000px;
    margin:auto;
    padding:40px 0;
}

section{
    margin-bottom:50px;
}

h2{
    margin-bottom:20px;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:white;
    padding:20px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.card h3{
    margin-bottom:10px;
}

.btn{
    display:inline-block;
    margin-top:10px;
    padding:10px 20px;
    background:#0ea5e9;
    color:white;
    text-decoration:none;
    border-radius:8px;
}

.btn:hover{
    background:#0284c7;
}

footer{
    text-align:center;
    padding:20px;
    background:white;
}

</style>
</head>
<body>

<header>

    <img src="foto.jpg" alt="Foto Profil" class="profile">

    <h1>Muhammad Habibullah Al Hikam</h1>
    <p>Mahasiswa Ilmu Komputer Universitas Lampung</p>

</header>

